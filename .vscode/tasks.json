        {
            "label": "exec pandoc (current file)",
            "type": "shell",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "windows": {
                "command": "bash -i \"%DOCSFW_HOME%/bin/pub_markdown_core.sh\" --workspaceFolder=\"${workspaceFolder}\" --relativeFile=\"${relativeFile}\"",
                "options": {
                    "envFile": "${workspaceFolder}/.vscode/.env.windows",
                    "shell": {
                        "executable": "cmd.exe",
                        "args": ["/c"]
                    }
                }
            },
            "linux": {
                "command": "bash -i \"$DOCSFW_HOME/bin/pub_markdown_core.sh\" --workspaceFolder=\"${workspaceFolder}\" --relativeFile=\"${relativeFile}\"",
                "options": {
                    "envFile": "${workspaceFolder}/.vscode/.env.linux"
                }
            }
        },
