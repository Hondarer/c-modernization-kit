            "label": "make clean",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always", // Terminal パネルを必ず開く
                "clear": true // 実行前に Terminal をクリア
            },
            "problemMatcher": [
