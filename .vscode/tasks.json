        {
            "label": "exec pandoc",
            "type": "shell",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "..\\pub_markdown\\bin\\pub_markdown.cmd /workspaceFolder:\"${workspaceFolder}\"",
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": ["/c"]
                    }
                }
            },
            "linux": {
                "command": "bash -i ../pub_markdown/bin/pub_markdown_core.sh --workspaceFolder=\"${workspaceFolder}\""
            }
        },
