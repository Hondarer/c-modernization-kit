{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug current directory test",
            "type": "cppdbg",
            "request": "launch",
            "program": "/bin/bash",
            "args": [
                "-c",
                "ulimit -s `ulimit -H -s` && ./$(basename `pwd`)"
            ],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "make all (current dir)",
            "miDebuggerPath": "/usr/bin/gdb",
            "logging": {
                "engineLogging": true
            },
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Debug add.exe (Windows POC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/prod/calc/src/add/add.exe",
            "args": [
                "10",
                "20"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/prod/calc/src/add",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}\\prod\\calc\\lib;${env:PATH}"
                }
            ],
            "console": "integratedTerminal",
            "preLaunchTask": "Build Windows POC"
        },
        {
            "name": "Debug calc.exe (Windows POC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/prod/calc/src/calc/calc.exe",
            "args": [
                "1",
                "10",
                "20"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/prod/calc/src/calc",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}\\prod\\calc\\lib;${env:PATH}"
                }
            ],
            "console": "integratedTerminal",
            "preLaunchTask": "Build Windows POC"
        },
        {
            "name": "Debug shared-and-static-add.exe (Windows POC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/prod/calc/src/shared-and-static-add/shared-and-static-add.exe",
            "args": [
                "10",
                "20"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/prod/calc/src/shared-and-static-add",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}\\prod\\calc\\lib;${env:PATH}"
                }
            ],
            "console": "integratedTerminal",
            "preLaunchTask": "Build Windows POC"
        }
    ]
}
