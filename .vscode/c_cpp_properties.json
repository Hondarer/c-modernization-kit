{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/app/calc/prod/include",
                "${workspaceFolder}/app/calc/test/include",
                "${workspaceFolder}/app/com_util/prod/include",
                "${workspaceFolder}/app/com_util/test/include",
                "${workspaceFolder}/app/doxygen-sample/prod/include",
                "${workspaceFolder}/app/override-sample/prod/include",
                "${workspaceFolder}/app/porter/prod/include",
                "${workspaceFolder}/app/porter/prod/libsrc/porter",
                "${workspaceFolder}/app/porter/test/include",
                "${workspaceFolder}/app/subfolder-sample/prod/include",
                "${workspaceFolder}/framework/testfw/gtest/include",
                "${workspaceFolder}/framework/testfw/include"
            ],
            "defines": [
                "TARGET_ARCH=target_arch", // framework/makefw/makefiles/prepare.mk で定義される TARGET_ARCH をインテリセンスで模擬するため (コンパイル時には環境に応じて適切な値が渡される)
                "_DEFAULT_SOURCE"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        },
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/app/calc/prod/include",
                "${workspaceFolder}/app/calc/test/include",
                "${workspaceFolder}/app/com_util/prod/include",
                "${workspaceFolder}/app/com_util/test/include",
                "${workspaceFolder}/app/doxygen-sample/prod/include",
                "${workspaceFolder}/app/override-sample/prod/include",
                "${workspaceFolder}/app/porter/prod/include",
                "${workspaceFolder}/app/porter/prod/libsrc/porter",
                "${workspaceFolder}/app/porter/test/include",
                "${workspaceFolder}/app/subfolder-sample/prod/include",
                "${workspaceFolder}/framework/testfw/gtest/include",
                "${workspaceFolder}/framework/testfw/include"
            ],
            "defines": [
                "TARGET_ARCH=target_arch" // framework/makefw/makefiles/prepare.mk で定義される TARGET_ARCH をインテリセンスで模擬するため (コンパイル時には環境に応じて適切な値が渡される)
            ],
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-msvc-x64"
        }
    ],
    "version": 4
