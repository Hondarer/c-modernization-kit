{
    "editor.renderWhitespace": "all",
    "explorer.compactFolders": false,
    "terminal.integrated.scrollback": 20000,
    "makefile.configureOnOpen": false,
    "files.associations": {
        "c_cpp_properties.json": "jsonc",
        ".debug-params.json": "jsonc",
        "**/.text_style_jp/*.json": "jsonc",
        "Doxyfile.part": "shellscript",
        "Doxyfile.part.*": "shellscript"
    },
    "terminal.integrated.env.linux": {
        "MAKEFW_HOME": "${workspaceFolder}/framework/makefw",
        "DOXYFW_HOME": "${workspaceFolder}/framework/doxyfw",
        "TESTFW_HOME": "${workspaceFolder}/framework/testfw",
        "DOCSFW_HOME": "${workspaceFolder}/framework/docsfw",
        "LD_LIBRARY_PATH": "${workspaceFolder}/app/calc/prod/lib:${workspaceFolder}/app/calc.net/prod/lib:${workspaceFolder}/app/override-sample/prod/lib:${workspaceFolder}/app/porter/prod/lib:${workspaceFolder}/app/com_util/prod/lib:${workspaceFolder}/app/tutorial/prod/lib",
        "PATH": "${workspaceFolder}/app/calc/prod/cbin:${workspaceFolder}/app/calc.net/prod/cbin:${workspaceFolder}/app/override-sample/prod/cbin:${workspaceFolder}/app/porter/prod/cbin:${workspaceFolder}/app/com_util/prod/cbin:${workspaceFolder}/app/tutorial/prod/cbin:${env:PATH}"
    },
    "terminal.integrated.env.windows": {
        "MAKEFW_HOME": "${workspaceFolder}/framework/makefw",
        "DOXYFW_HOME": "${workspaceFolder}/framework/doxyfw",
        "TESTFW_HOME": "${workspaceFolder}/framework/testfw",
        "DOCSFW_HOME": "${workspaceFolder}/framework/docsfw",
        "PATH": "${workspaceFolder}\\app\\calc\\prod\\lib;${workspaceFolder}\\app\\calc\\prod\\cbin;${workspaceFolder}\\app\\calc.net\\prod\\lib;${workspaceFolder}\\app\\calc.net\\prod\\cbin;${workspaceFolder}\\app\\override-sample\\prod\\lib;${workspaceFolder}\\app\\override-sample\\prod\\cbin;${workspaceFolder}\\app\\porter\\prod\\lib;${workspaceFolder}\\app\\porter\\prod\\cbin;${workspaceFolder}\\app\\com_util\\prod\\lib;${workspaceFolder}\\app\\com_util\\prod\\cbin;${workspaceFolder}\\app\\tutorial\\prod\\lib;${workspaceFolder}\\app\\tutorial\\prod\\cbin;${env:PATH}"
    },
    "dotnet.defaultSolution": "disable",
    "C_Cpp.formatting": "clangFormat",
    "debugParams.defaults": {
        "program": "${shell:make show-exepath}"
    },
    "todohighlight.keywords": [
        {
            "text": "@todo",
            "color": "#fff",
            "backgroundColor": "#ffbd2a",
            "overviewRulerColor": "rgba(255,189,42,0.8)"
        },
    ], // https://marketplace.visualstudio.com/items?itemName=wayou.vscode-todo-highlight
    // oracle-linux-container および devbin-win によってセットアップされた環境では、
    // PLANTUML_HOME が利用可能
    "markdown-preview-enhanced.plantumlJarPath": "${env:PLANTUML_HOME}/plantuml.jar",
}
