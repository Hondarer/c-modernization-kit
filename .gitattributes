# Repository-wide line ending policy
# .editorconfig の `end_of_line = lf`、.clang-format の `UseCRLF: false` と整合させる。
* text=auto eol=lf

# Windows executable scripts
# .editorconfig の `[*.{bat,cmd}] end_of_line = crlf` と整合させる。
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
# Keep draw.io exported SVG out of text normalization/diff conversion
*.drawio.svg binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
